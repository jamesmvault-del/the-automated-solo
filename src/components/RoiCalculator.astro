---
interface Props {
  defaultHoursSaved?: number;
  defaultRate?: number;
}
const { defaultHoursSaved = 5, defaultRate = 250 } = Astro.props;
---
<div class="my-10 p-8 rounded-2xl border border-slate-800 bg-slate-900/40 backdrop-blur-md shadow-2xl font-sans relative overflow-hidden not-prose">
  <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-emerald-500/20 via-emerald-400 to-emerald-500/20"></div>
  <div class="flex flex-col md:flex-row gap-8 items-center">
    <div class="w-full md:w-1/2 space-y-6">
      <div>
        <h3 class="text-2xl font-serif text-white mb-1">Billable ROI Calculator</h3>
        <p class="text-slate-400 text-sm">Quantify the actual financial value of this automation over a 48-week working year.</p>
      </div>
      
      <div class="space-y-6 bg-slate-950/50 p-5 rounded-xl border border-slate-800/80">
        <div>
          <div class="flex justify-between mb-3">
            <label class="text-sm font-medium text-slate-300">Your Hourly Rate</label>
            <span class="text-emerald-400 font-mono text-sm" id="rate-display">${defaultRate}/hr</span>
          </div>
          <input type="range" id="rate-slider" min="100" max="1000" step="25" value={defaultRate} class="w-full h-1.5 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-emerald-500" />
        </div>
        
        <div class="pt-2 border-t border-slate-800">
          <div class="flex justify-between mb-3 mt-2">
            <label class="text-sm font-medium text-slate-300">Hours Saved Per Week</label>
            <span class="text-emerald-400 font-mono text-sm" id="hours-display">{defaultHoursSaved} hrs</span>
          </div>
          <input type="range" id="hours-slider" min="0.5" max="20" step="0.5" value={defaultHoursSaved} class="w-full h-1.5 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-emerald-500" />
        </div>
      </div>
    </div>
    
    <div class="w-full md:w-1/2 rounded-xl p-8 border border-slate-800/80 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-slate-800/40 via-slate-900/20 to-slate-950 
 flex flex-col items-center justify-center text-center relative max-w-sm mx-auto shadow-inner">
      <div class="absolute inset-0 bg-emerald-900/5 blur-[50px] rounded-full pointer-events-none"></div>
      <p class="text-slate-400 text-[11px] uppercase tracking-[0.2em] mb-3 relative z-10 font-semibold">Annual Revenue Recovered</p>
      <div class="text-4xl md:text-5xl font-serif text-white tracking-tight relative z-10" id="roi-result">$0</div>
    </div>
  </div>
</div>

<script>
  function setupRoiCalculator() {
    const rateSlider = document.getElementById('rate-slider') as HTMLInputElement;
    const hoursSlider = document.getElementById('hours-slider') as HTMLInputElement;
    const rateDisplay = document.getElementById('rate-display');
    const hoursDisplay = document.getElementById('hours-display');
    const roiResult = document.getElementById('roi-result');

    if(!rateSlider || !hoursSlider || !rateDisplay || !hoursDisplay || !roiResult) return;

    function calculate() {
      const rate = parseFloat(rateSlider.value);
      const hours = parseFloat(hoursSlider.value);
      
      rateDisplay.textContent = `$${rate}/hr`;
      hoursDisplay.textContent = `${hours} hrs`;
      
      const annual = rate * hours * 48;
      roiResult.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(annual);
    }

    rateSlider.addEventListener('input', calculate);
    hoursSlider.addEventListener('input', calculate);
    calculate(); 
  }

  // Support Astro view transitions 
  document.addEventListener('astro:page-load', setupRoiCalculator);
  // Initial load
  setupRoiCalculator();
</script>