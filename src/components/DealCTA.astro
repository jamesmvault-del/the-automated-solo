---
interface Props {
  link: string;
  productName: string;
  price: string;
}

const { link, productName, price } = Astro.props;
---

<div class="not-prose mt-16 rounded-3xl relative overflow-hidden group">
  <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/20 via-slate-800/20 to-slate-800/80 rounded-3xl z-0"></div>
  <div class="absolute inset-[1px] bg-slate-950/90 backdrop-blur-xl rounded-[23px] z-0"></div>

  <div class="absolute -top-32 -right-32 w-64 h-64 bg-emerald-500/10 rounded-full blur-[80px] pointer-events-none z-0 transition-opacity duration-700 group-hover:opacity-100 opacity-50"></div>

  <div class="relative z-10 p-8 sm:p-10 flex flex-col items-center sm:items-start text-center sm:text-left gap-6">
    
    <div class="inline-flex items-center gap-2.5 px-3 py-1.5 rounded-full bg-slate-900 border border-slate-800 text-emerald-400 text-xs font-semibold tracking-wide uppercase shadow-sm">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_8px_rgba(52,211,153,0.8)]"></span>
      Active Deal Verified
    </div>

    <div class="w-full flex flex-col sm:flex-row items-center justify-between gap-8">
      <div class="flex-1">
        <h3 class="text-2xl sm:text-3xl font-bold tracking-tight text-white mb-3">
          Unlock {productName} Permanently
        </h3>
        <p class="text-slate-400 text-base max-w-lg leading-relaxed">
          Skip the monthly subscription trap. Claim the lifetime deal for a one-time payment of <span class="text-white font-medium border-b border-emerald-500/50 pb-0.5">{price}</span> before it sells out.
        </p>
      </div>

      <div class="flex-shrink-0 w-full sm:w-auto">
        <a
          href={link}
          target="_blank"
          rel="noopener noreferrer"
          class="group/btn relative inline-flex w-full sm:w-auto items-center justify-center gap-3 px-8 py-4 bg-white text-slate-950 font-semibold rounded-xl overflow-hidden active:scale-[0.98] transition-all shadow-[0_4px_20px_-4px_rgba(255,255,255,0.4)] hover:shadow-[0_8px_30px_-4px_rgba(255,255,255,0.6)] border border-white/90 hover:border-white"
        >
          <div class="absolute inset-0 bg-gradient-to-b from-white to-slate-100 opacity-100 group-hover/btn:opacity-0 transition-opacity duration-300"></div>
          <div class="absolute inset-0 bg-gradient-to-b from-slate-50 to-slate-200 opacity-0 group-hover/btn:opacity-100 transition-opacity duration-300"></div>
          
          <span class="relative z-10 flex items-center gap-2">
            Get the Lifetime Deal
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600 group-hover/btn:translate-x-1 group-hover/btn:scale-110 transition-all duration-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </span>
        </a>
      </div>
    </div>

    <div class="w-full mt-2 pt-6 border-t border-slate-800/80 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-500">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span>Verified AppSumo Partner Listing</span>
      </div>
      <div class="text-center sm:text-right italic max-w-xl">
        FTC Disclosure: I use test-verified affiliate links. If you purchase through this link, I earn a minor commission to keep the lab running. It costs you strictly nothing extra.
      </div>
    </div>
  </div>
</div>
