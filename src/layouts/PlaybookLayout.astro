---
import Layout from './Layout.astro';
const { title, description, pubDate, lastUpdated, readTime, author, image, contentType = 'playbook' } = Astro.props.frontmatter || Astro.props;
const isResearch = contentType === 'research';
const backLabel = isResearch ? 'Back to Research' : 'Back to Playbooks';
const backHref = isResearch ? '/research' : '/playbooks';
const displayDate = lastUpdated || pubDate;
const showUpdatedBadge = lastUpdated && pubDate && new Date(lastUpdated).getTime() !== new Date(pubDate).getTime();
---

<Layout title={title} description={description} image={image}>
  <main class="min-h-screen bg-slate-950 text-slate-300 py-20 px-6 sm:px-12">   
    <article class="max-w-3xl mx-auto animate-fade-in-up">
      <header class="mb-12 border-b border-slate-800 pb-8">
        <a href={backHref} class="text-emerald-500 hover:text-emerald-400 font-medium tracking-wide text-sm mb-6 inline-block uppercase transition-colors">&larr; {backLabel}</a>
        <h1 class="text-4xl md:text-5xl font-serif text-white leading-tight mb-6">{title}</h1>
        <p class="text-xl text-slate-400 font-light leading-relaxed mb-6">{description}</p>
        
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-500 mb-8">
          <div class="flex items-center gap-2">
            <span class="w-8 h-8 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center text-slate-300 font-medium shadow-inner">J</span>
            <span class="font-medium text-slate-300">{author}</span>
          </div>
          <span>&bull;</span>
          <time datetime={new Date(displayDate).toISOString()}>{new Date(displayDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          {showUpdatedBadge && (
            <span class="inline-flex items-center gap-1 text-emerald-400 text-xs font-medium bg-emerald-400/10 px-2 py-0.5 rounded-full">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
              Updated
            </span>
          )}
          {readTime && (
            <>
              <span>&bull;</span>
              <span>{readTime}</span>
            </>
          )}
        </div>

        {image && (
          <div class="w-full aspect-video md:aspect-[21/9] rounded-2xl overflow-hidden border border-slate-800 relative shadow-2xl mt-8 group">
            <div class="absolute inset-0 bg-slate-900/20 backdrop-blur-[2px] opacity-0 group-hover:opacity-100 transition-opacity z-10 duration-500"></div>
            <img src={image} alt={`Cover for ${title}`} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
          </div>
        )}
      </header>

      <div class="prose prose-invert prose-slate md:prose-lg max-w-none prose-headings:font-serif prose-headings:text-white prose-a:text-emerald-400 prose-a:no-underline hover:prose-a:underline prose-strong:text-white prose-blockquote:border-l-emerald-500 prose-blockquote:bg-slate-900/50 prose-blockquote:py-1 prose-blockquote:px-5 prose-blockquote:rounded-r-md prose-blockquote:not-italic prose-blockquote:text-slate-300">
        <slot />
      </div>
    </article>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": title,
      "description": description,
      "datePublished": pubDate ? new Date(pubDate).toISOString() : undefined,
      "dateModified": lastUpdated ? new Date(lastUpdated).toISOString() : (pubDate ? new Date(pubDate).toISOString() : undefined),
      "author": {
        "@type": "Person",
        "name": author || "James"
      },
      "publisher": {
        "@type": "Organization",
        "name": "The Automated Solo"
      },
      "image": image ? `https://theautomatedsolo.com${image}` : undefined
    })} />
  </main>
</Layout>
