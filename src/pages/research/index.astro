---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allResearch = await getCollection('research');
const sortedResearch = allResearch
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Research" description="Deep-dive audits and benchmarking reports on AI, security, and legal technology for solo practitioners.">
  <main class="min-h-screen bg-slate-950 py-20 px-6 sm:px-12 text-slate-300">
    <div class="max-w-6xl mx-auto">
      <header class="mb-12">
        <div class="inline-flex items-center px-3 py-1.5 rounded-full border border-slate-700/50 bg-slate-800/30 backdrop-blur-md text-sm text-slate-300 font-medium tracking-wide mb-6">
          <span class="flex h-2 w-2 rounded-full bg-amber-400 mr-2"></span>
          Verified Research
        </div>
        <h1 class="text-4xl md:text-5xl font-serif text-white mb-4">Research Reports</h1>
        <p class="text-xl text-slate-400 font-light max-w-3xl">In-depth audits of AI models, security practices, and legal technology. We test what the marketing copy won't tell you.</p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedResearch.map((report) => (
          <a href={`/research/${report.id}`} class="group relative flex flex-col rounded-2xl border border-slate-800 bg-slate-900/40 hover:bg-slate-800/60 transition-all duration-300 backdrop-blur-md shadow-lg hover:shadow-[0_0_30px_rgba(16,185,129,0.05)] overflow-hidden">
            {report.data.image && (
              <div class="w-full aspect-video overflow-hidden bg-slate-900 border-b border-slate-800">
                <img src={report.data.image} alt={report.data.title} width="1408" height="768" loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
              </div>
            )}
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">
                  {report.data.tags ? report.data.tags[0] : 'Research'}
                </span>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-amber-500/10 text-amber-400 border border-amber-500/20">
                  <span class="w-1.5 h-1.5 rounded-full bg-amber-400 mr-1.5 animate-pulse"></span>
                  Verified
                </span>
              </div>
              <h2 class="text-xl font-serif text-white mb-2 group-hover:text-amber-400 transition-colors">{report.data.title}</h2>
              <p class="text-sm text-slate-400 leading-relaxed mb-4 flex-grow">{report.data.description}</p>
              <div class="flex items-center gap-3 pt-4 border-t border-slate-800/60 text-xs text-slate-500">
                <span>{report.data.author}</span>
                <span class="w-1 h-1 rounded-full bg-slate-700"></span>
                <span>{report.data.readTime}</span>
                <span class="w-1 h-1 rounded-full bg-slate-700"></span>
                <time>{new Date(report.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
