---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const playbooks = (await getCollection('playbooks')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Automation Playbooks" description="Step-by-step automation playbooks built for solo attorneys. Copy these workflows to save hours every week on intake, referrals, and client management.">
  <main class="min-h-screen bg-slate-950 text-slate-300 py-20 px-6 sm:px-12">
    <div class="max-w-6xl mx-auto">
      <header class="mb-12">
        <div class="inline-flex items-center px-3 py-1.5 rounded-full border border-slate-700/50 bg-slate-800/30 backdrop-blur-md text-sm text-slate-300 font-medium tracking-wide mb-6">
          <span class="flex h-2 w-2 rounded-full bg-emerald-400 mr-2"></span>
          Tested Systems
        </div>
        <h1 class="text-4xl md:text-5xl font-serif text-white mb-4">Automation Playbooks</h1>
        <p class="text-xl text-slate-400 font-light max-w-3xl">Tested systems and automated pipelines to reclaim your billable hours.</p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {playbooks.map((playbook) => (
          <a href={`/playbooks/${playbook.id}`} class="group relative flex flex-col rounded-2xl border border-slate-800 bg-slate-900/40 hover:bg-slate-800/60 transition-all duration-300 backdrop-blur-md shadow-lg hover:shadow-[0_0_30px_rgba(16,185,129,0.05)] overflow-hidden">
            {playbook.data.image && (
              <div class="w-full aspect-video overflow-hidden bg-slate-900 border-b border-slate-800">
                <img src={playbook.data.image} alt={playbook.data.title} width="1408" height="768" loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
              </div>
            )}
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">
                  {playbook.data.tags ? playbook.data.tags[0] : 'Playbook'}
                </span>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 mr-1.5"></span>
                  System
                </span>
              </div>
              <h2 class="text-xl font-serif text-white mb-2 group-hover:text-emerald-400 transition-colors">{playbook.data.title}</h2>
              <p class="text-sm text-slate-400 leading-relaxed mb-4 flex-grow">{playbook.data.description}</p>
              <div class="flex items-center gap-3 pt-4 border-t border-slate-800/60 text-xs text-slate-500">
                <span>{playbook.data.author}</span>
                <span class="w-1 h-1 rounded-full bg-slate-700"></span>
                <span>{playbook.data.readTime}</span>
                <span class="w-1 h-1 rounded-full bg-slate-700"></span>
                <time>{new Date(playbook.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
