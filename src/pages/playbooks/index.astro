---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const playbooks = (await getCollection('playbooks')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Automation Playbooks">
  <main class="min-h-screen bg-slate-950 text-slate-300 py-20 px-6 sm:px-12">
    <div class="max-w-4xl mx-auto animate-fade-in-up">
      <header class="mb-16">
        <a href="/" class="text-emerald-500 hover:text-emerald-400 font-medium tracking-wide text-sm mb-6 inline-block uppercase transition-colors">← Home</a>
        <h1 class="text-4xl md:text-5xl font-serif text-white mb-4">The Automation Playbooks</h1>
        <p class="text-xl text-slate-400 font-light">Tested systems and automated pipelines to reclaim your billable hours.</p>
      </header>

      <div class="grid gap-8">
        {playbooks.map((playbook) => (
          <article class="group relative rounded-2xl border border-slate-800 bg-slate-900/50 hover:bg-slate-800/80 transition-all duration-300 hover:shadow-[0_0_30px_rgba(16,185,129,0.05)] overflow-hidden flex flex-col md:flex-row">
            {playbook.data.image && (
              <div class="w-full md:w-1/3 lg:w-2/5 shrink-0 overflow-hidden bg-slate-900 relative">
                <div class="absolute inset-0 bg-slate-900/20 backdrop-blur-[1px] opacity-0 group-hover:opacity-100 transition-opacity z-10 duration-500"></div>
                <img src={playbook.data.image} alt={playbook.data.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 min-h-[200px]" />
              </div>
            )}
            <div class="p-6 md:p-8 flex flex-col justify-center w-full relative">
              <div class="flex items-center gap-4 text-sm text-slate-500 mb-4 relative z-20">
                <time datetime={playbook.data.pubDate.toISOString()}>
                  {playbook.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {playbook.data.readTime && (
                  <>
                    <span>&bull;</span>
                    <span>{playbook.data.readTime}</span>
                  </>
                )}
                {playbook.data.tags && playbook.data.tags.length > 0 && (
                  <>
                    <span>&bull;</span>
                    <span class="text-emerald-500/80 font-medium">{playbook.data.tags[0]}</span>
                  </>
                )}
              </div>
              <h2 class="text-2xl font-serif text-white mb-3 group-hover:text-emerald-400 transition-colors">
                <a href={`/playbooks/${playbook.id}`}>
                  <span class="absolute inset-0 z-10"></span>
                  {playbook.data.title}
                </a>
              </h2>
              <p class="text-slate-400 leading-relaxed relative z-20">
                {playbook.data.description}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>
</Layout>
