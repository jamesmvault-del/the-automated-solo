---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTools = await getCollection('tools');
const allPlaybooks = await getCollection('playbooks');

// Extract dollar amount from strings like "$29 Lifetime" or "$49/mo"
function extractPrice(str: string): number {
  const m = str.match(/\$([\d,]+)/);
  return m ? parseInt(m[1].replace(',', '')) : 0;
}

// Match tools to related playbooks by overlapping category keywords and playbook tags
function findRelatedPlaybooks(tool: typeof allTools[0]) {
  const keywords = tool.data.category.toLowerCase().split(/[\s&,]+/).filter(w => w.length > 2);
  return allPlaybooks.filter(pb =>
    (pb.data.tags || []).some(tag => keywords.includes(tag.toLowerCase()))
  );
}

// Playbooks not matched to any tool (standalone automation strategies)
const matchedPbIds = new Set<string>();
allTools.forEach(t => findRelatedPlaybooks(t).forEach(pb => matchedPbIds.add(pb.id)));
const standalonePlaybooks = allPlaybooks.filter(pb => !matchedPbIds.has(pb.id));

// Cost breakdown by deal type
const ltdTools = allTools.filter(t => t.data.dealType === 'Lifetime Deal');
const saasTools = allTools.filter(t => t.data.dealType !== 'Lifetime Deal');
const totalLtdCost = ltdTools.reduce((sum, t) => sum + extractPrice(t.data.dealPrice), 0);
const equivalentMonthly = ltdTools.reduce((sum, t) => sum + extractPrice(t.data.standardPrice), 0);
const totalSaasMonthly = saasTools.reduce((sum, t) => sum + extractPrice(t.data.dealPrice), 0);
const breakEvenMonths = equivalentMonthly > 0 ? Math.ceil(totalLtdCost / equivalentMonthly) : 0;
---

<Layout title="Automation Savings Calculator" description="Calculate how much billable revenue your solo practice is losing to manual admin work every year. Adjust the sliders to match your firm.">
  <main class="min-h-screen bg-slate-950 py-20 px-6 sm:px-12 text-slate-300">
    <div class="max-w-4xl mx-auto animate-fade-in-up">
      <header class="mb-12">
        <a href="/" class="text-emerald-500 hover:text-emerald-400 font-medium tracking-wide text-sm mb-6 inline-block uppercase transition-colors">&larr; Home</a>
        <h1 class="text-4xl md:text-5xl font-serif text-white mb-4">Automation Savings Calculator</h1>
        <p class="text-xl text-slate-400 font-light max-w-3xl">Most solo attorneys lose between $50,000 and $150,000 per year to tasks that could be fully automated. Adjust the sliders below to see what your firm is actually leaving on the table.</p>
      </header>

      <!-- Calculator Card -->
      <div class="p-8 md:p-10 rounded-2xl border border-slate-800 bg-slate-900/40 backdrop-blur-md shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-emerald-500/20 via-emerald-400 to-emerald-500/20"></div>

        <!-- Input Sliders -->
        <div class="space-y-8 mb-10">
          <!-- Hourly Rate -->
          <div class="bg-slate-950/50 p-6 rounded-xl border border-slate-800/80">
            <div class="flex justify-between mb-3">
              <label class="text-sm font-medium text-slate-300">Your Billable Hourly Rate</label>
              <span class="text-emerald-400 font-mono text-sm" id="calc-rate-display">$300/hr</span>
            </div>
            <input type="range" id="calc-rate" min="100" max="1000" step="25" value="300" class="w-full h-1.5 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-emerald-500" />
            <div class="flex justify-between text-xs text-slate-600 mt-2">
              <span>$100/hr</span>
              <span>$1,000/hr</span>
            </div>
          </div>

          <!-- Client Intake -->
          <div class="bg-slate-950/50 p-6 rounded-xl border border-slate-800/80">
            <div class="flex justify-between items-start gap-4 mb-3">
              <div class="min-w-0">
                <label class="text-sm font-medium text-slate-300">Client Intake & Data Entry</label>
                <p class="text-xs text-slate-500 mt-1">Copying info from forms to your CRM, creating contacts, opening matters</p>
              </div>
              <span class="text-emerald-400 font-mono text-sm whitespace-nowrap" id="calc-intake-display">3 hrs/wk</span>
            </div>
            <input type="range" id="calc-intake" min="0" max="15" step="0.5" value="3" class="w-full h-1.5 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-emerald-500" />
          </div>

          <!-- Email & Drafting -->
          <div class="bg-slate-950/50 p-6 rounded-xl border border-slate-800/80">
            <div class="flex justify-between items-start gap-4 mb-3">
              <div class="min-w-0">
                <label class="text-sm font-medium text-slate-300">Repetitive Emails & Drafting</label>
                <p class="text-xs text-slate-500 mt-1">Status updates, follow-ups, appointment confirmations, template letters</p>
              </div>
              <span class="text-emerald-400 font-mono text-sm whitespace-nowrap" id="calc-email-display">4 hrs/wk</span>
            </div>
            <input type="range" id="calc-email" min="0" max="15" step="0.5" value="4" class="w-full h-1.5 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-emerald-500" />
          </div>

          <!-- Scheduling -->
          <div class="bg-slate-950/50 p-6 rounded-xl border border-slate-800/80">
            <div class="flex justify-between items-start gap-4 mb-3">
              <div class="min-w-0">
                <label class="text-sm font-medium text-slate-300">Scheduling & Calendar Management</label>
                <p class="text-xs text-slate-500 mt-1">Back-and-forth booking, rescheduling, reminders, no-show follow-ups</p>
              </div>
              <span class="text-emerald-400 font-mono text-sm whitespace-nowrap" id="calc-sched-display">2 hrs/wk</span>
            </div>
            <input type="range" id="calc-sched" min="0" max="10" step="0.5" value="2" class="w-full h-1.5 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-emerald-500" />
          </div>

          <!-- Marketing -->
          <div class="bg-slate-950/50 p-6 rounded-xl border border-slate-800/80">
            <div class="flex justify-between items-start gap-4 mb-3">
              <div class="min-w-0">
                <label class="text-sm font-medium text-slate-300">Client Nurturing & Marketing</label>
                <p class="text-xs text-slate-500 mt-1">Newsletter writing, referral outreach, check-in emails, social updates</p>
              </div>
              <span class="text-emerald-400 font-mono text-sm whitespace-nowrap" id="calc-mktg-display">2 hrs/wk</span>
            </div>
            <input type="range" id="calc-mktg" min="0" max="10" step="0.5" value="2" class="w-full h-1.5 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-emerald-500" />
          </div>
        </div>

        <!-- Results Dashboard -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Total Hours -->
          <div class="rounded-xl p-6 border border-slate-800/80 bg-slate-950/50 text-center">
            <p class="text-slate-400 text-[11px] uppercase tracking-[0.2em] mb-2 font-semibold">Weekly Hours Lost</p>
            <div class="text-3xl font-serif text-white" id="calc-total-hours">11 hrs</div>
          </div>

          <!-- Annual Revenue -->
          <div class="rounded-xl p-6 border border-emerald-800/40 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/20 via-slate-900/20 to-slate-950 text-center relative shadow-inner">
            <div class="absolute inset-0 bg-emerald-900/5 blur-[50px] rounded-full pointer-events-none"></div>
            <p class="text-emerald-400/80 text-[11px] uppercase tracking-[0.2em] mb-2 font-semibold relative z-10">Annual Revenue Lost</p>
            <div class="text-3xl sm:text-4xl font-serif text-white tracking-tight relative z-10" id="calc-annual">$158,400</div>
          </div>

          <!-- Monthly Equivalent -->
          <div class="rounded-xl p-6 border border-slate-800/80 bg-slate-950/50 text-center">
            <p class="text-slate-400 text-[11px] uppercase tracking-[0.2em] mb-2 font-semibold">Per Month</p>
            <div class="text-3xl font-serif text-white" id="calc-monthly">$13,200</div>
          </div>
        </div>
      </div>

      <!-- Context Section: auto-populated from content collections -->
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-6 rounded-xl border border-slate-800 bg-slate-900/30">
          <h3 class="text-white font-serif text-lg mb-3">What Can Be Automated?</h3>
          <ul class="space-y-3 text-slate-400 text-sm">
            {allTools.map(tool => {
              const related = findRelatedPlaybooks(tool);
              return (
                <li class="flex items-start gap-3">
                  <span class="text-emerald-400 mt-0.5">&#10003;</span>
                  <span>
                    <strong class="text-white">{tool.data.category}</strong>: {tool.data.useCase}{' '}
                    <a href={`/tools/${tool.id}`} class="text-emerald-400 hover:underline">{tool.data.name} &rarr;</a>
                    {related.map(pb => (
                      <span class="block mt-1 text-slate-500">Related playbook: <a href={`/playbooks/${pb.id}`} class="text-emerald-400 hover:underline">{pb.data.title}</a></span>
                    ))}
                  </span>
                </li>
              );
            })}
            {standalonePlaybooks.map(pb => (
              <li class="flex items-start gap-3">
                <span class="text-emerald-400 mt-0.5">&#10003;</span>
                <span>
                  <strong class="text-white">{pb.data.title}</strong>: {pb.data.description}{' '}
                  <a href={`/playbooks/${pb.id}`} class="text-emerald-400 hover:underline">Read the playbook &rarr;</a>
                </span>
              </li>
            ))}
          </ul>
        </div>

        <div class="p-6 rounded-xl border border-slate-800 bg-slate-900/30">
          <h3 class="text-white font-serif text-lg mb-3">{saasTools.length === 0 ? 'The Lifetime Deal Advantage' : 'The Cost Advantage'}</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">
            {saasTools.length === 0
              ? 'Every tool we recommend on this site is available as a one-time purchase. No monthly subscriptions eating into the savings you just calculated.'
              : 'We prioritize lifetime deals wherever possible, and only recommend subscriptions when the time savings clearly justify the recurring cost.'}
          </p>
          <div class="space-y-3">
            {ltdTools.length > 0 &&
              <div class="flex justify-between items-center text-sm border-b border-slate-800/60 pb-2">
                <span class="text-slate-300">Lifetime deal tools ({ltdTools.length})</span>
                <span class="text-emerald-400 font-mono font-medium">~${totalLtdCost} one-time</span>
              </div>
            }
            {ltdTools.length > 0 &&
              <div class="flex justify-between items-center text-sm border-b border-slate-800/60 pb-2">
                <span class="text-slate-300">Same tools at retail</span>
                <span class="text-slate-500 font-mono">~${equivalentMonthly}/mo</span>
              </div>
            }
            {ltdTools.length > 0 &&
              <div class="flex justify-between items-center text-sm border-b border-slate-800/60 pb-2">
                <span class="text-slate-300">Break-even on lifetime deals</span>
                <span class="text-emerald-400 font-mono font-medium">~{breakEvenMonths} months</span>
              </div>
            }
            {saasTools.length > 0 &&
              <div class="flex justify-between items-center text-sm border-b border-slate-800/60 pb-2">
                <span class="text-slate-300">SaaS subscriptions ({saasTools.length})</span>
                <span class="text-slate-400 font-mono">~${totalSaasMonthly}/mo</span>
              </div>
            }
          </div>
          <a href="/tracker" class="mt-6 inline-block text-sm text-emerald-400 hover:underline font-medium">View the full Software Index &rarr;</a>
        </div>
      </div>

      <!-- PWA Prompt -->
      <div class="mt-12 text-center p-6 rounded-xl border border-dashed border-slate-700 bg-slate-900/20">
        <p class="text-slate-400 text-sm">Bookmark this calculator or <strong class="text-white">Add to Home Screen</strong> for instant access whenever you need to make a business case for automation.</p>
      </div>
    </div>
  </main>
</Layout>

<script>
  function setupCalculator() {
    const rate = document.getElementById('calc-rate') as HTMLInputElement;
    const intake = document.getElementById('calc-intake') as HTMLInputElement;
    const email = document.getElementById('calc-email') as HTMLInputElement;
    const sched = document.getElementById('calc-sched') as HTMLInputElement;
    const mktg = document.getElementById('calc-mktg') as HTMLInputElement;

    const rateDisplay = document.getElementById('calc-rate-display');
    const intakeDisplay = document.getElementById('calc-intake-display');
    const emailDisplay = document.getElementById('calc-email-display');
    const schedDisplay = document.getElementById('calc-sched-display');
    const mktgDisplay = document.getElementById('calc-mktg-display');

    const totalHours = document.getElementById('calc-total-hours');
    const annual = document.getElementById('calc-annual');
    const monthly = document.getElementById('calc-monthly');

    if (!rate || !intake || !email || !sched || !mktg) return;

    function calculate() {
      const r = parseFloat(rate.value);
      const hrs = parseFloat(intake.value) + parseFloat(email.value) + parseFloat(sched.value) + parseFloat(mktg.value);
      const annualValue = r * hrs * 48;
      const monthlyValue = Math.round(annualValue / 12);

      if (rateDisplay) rateDisplay.textContent = `$${r}/hr`;
      if (intakeDisplay) intakeDisplay.textContent = `${parseFloat(intake.value)} hrs/wk`;
      if (emailDisplay) emailDisplay.textContent = `${parseFloat(email.value)} hrs/wk`;
      if (schedDisplay) schedDisplay.textContent = `${parseFloat(sched.value)} hrs/wk`;
      if (mktgDisplay) mktgDisplay.textContent = `${parseFloat(mktg.value)} hrs/wk`;

      if (totalHours) totalHours.textContent = `${hrs} hrs`;
      if (annual) annual.textContent = `$${annualValue.toLocaleString()}`;
      if (monthly) monthly.textContent = `$${monthlyValue.toLocaleString()}`;
    }

    [rate, intake, email, sched, mktg].forEach(slider => {
      slider.addEventListener('input', calculate);
    });

    calculate();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupCalculator);
  } else {
    setupCalculator();
  }
</script>
