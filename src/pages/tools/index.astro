---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTools = await getCollection('tools');
const sortedTools = allTools.sort((a, b) => {
  if (a.data.dealType === 'Lifetime Deal' && b.data.dealType !== 'Lifetime Deal') return -1;
  if (a.data.dealType !== 'Lifetime Deal' && b.data.dealType === 'Lifetime Deal') return 1;
  return 0;
});
---

<Layout title="Software Notes" description="Hands-on reviews of legal automation software. Every tool is stress-tested for solo law practitioners before it makes this list.">
  <main class="min-h-screen bg-slate-950 py-20 px-6 sm:px-12 text-slate-300">
    <div class="max-w-6xl mx-auto">
      <header class="mb-12">
        <div class="inline-flex items-center px-3 py-1.5 rounded-full border border-slate-700/50 bg-slate-800/30 backdrop-blur-md text-sm text-slate-300 font-medium tracking-wide mb-6">
          <span class="flex h-2 w-2 rounded-full bg-emerald-500 mr-2"></span>
          Lab-Tested Reviews
        </div>
        <h1 class="text-4xl md:text-5xl font-serif text-white mb-4">Software Notes</h1>
        <p class="text-xl text-slate-400 font-light max-w-3xl">Every tool below has been through our full testing process. We connect the integrations, run the edge cases, and document the results so you can make a fast decision.</p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {sortedTools.map((tool) => (
          <a href={`/tools/${tool.id}`} class="group relative flex flex-col rounded-2xl border border-slate-800 bg-slate-900/40 hover:bg-slate-800/60 transition-all duration-300 backdrop-blur-md shadow-lg hover:shadow-[0_0_30px_rgba(16,185,129,0.05)] overflow-hidden">
            {tool.data.image && (
              <div class="w-full aspect-video overflow-hidden bg-slate-900 border-b border-slate-800">
                <img src={tool.data.image} alt={tool.data.name} width="1408" height="768" loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
              </div>
            )}
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">{tool.data.category}</span>
                {tool.data.dealType === 'Lifetime Deal' && (
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 mr-1.5 animate-pulse"></span>
                    Lifetime Deal
                  </span>
                )}
              </div>
              <h2 class="text-xl font-serif text-white mb-2 group-hover:text-emerald-400 transition-colors">{tool.data.name}</h2>
              <p class="text-sm text-slate-400 leading-relaxed mb-4 flex-grow">{tool.data.useCase}</p>
              <div class="flex items-center justify-between pt-4 border-t border-slate-800/60">
                <div>
                  <span class="text-slate-500 line-through text-sm mr-2">{tool.data.standardPrice}</span>
                  <span class="text-emerald-400 font-semibold">{tool.data.dealPrice}</span>
                </div>
                <span class="text-sm text-slate-500">Est. ROI: {tool.data.roiEstimate}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
